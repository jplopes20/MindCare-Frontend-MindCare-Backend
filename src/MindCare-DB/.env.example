# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/mindcare_db

# ============================================================================
# JWT
# ============================================================================
JWT_SECRET=sua-chave-secreta-super-segura-aqui

# ============================================================================
# REDIS (Cache de disponibilidade e rate limit)
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================================================
# SERVER
# ============================================================================
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ============================================================================
# EMAIL (Resend)
# ============================================================================
# Obtenha sua chave em https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=MindCare <noreply@mindcare.local>

# Alternativa: SendGrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx

# ============================================================================
# ARMAZENAMENTO (AWS S3 ou Cloudflare R2)
# ============================================================================
# Deixe STORAGE_BUCKET vazio para usar armazenamento local (./uploads)
# Para S3:
# STORAGE_REGION=us-east-1
# STORAGE_BUCKET=mindcare-documents
# STORAGE_ACCESS_KEY_ID=AKIAxxxxxxxxxxxx
# STORAGE_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxx
#
# Para Cloudflare R2:
# STORAGE_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# STORAGE_REGION=auto
# STORAGE_BUCKET=mindcare-documents
# STORAGE_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxx
# STORAGE_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Opcionais:
# STORAGE_PUBLIC_URL=https://pub-xxxxx.r2.dev
# MAX_FILE_SIZE=20971520
# LOCAL_STORAGE_PATH=./uploads

# ============================================================================
# IA ASSISTANT
# ============================================================================
# Deixe AI_PROVIDER vazio ou 'simulated' para usar respostas simuladas
# Para usar um LLM real, implemente o provider em src/modules/domain/providers/
# e altere para: AI_PROVIDER=openai
AI_PROVIDER=simulated
